Module
  name: game_proficiency
  description: Weapon Proficiency System
  sandboxed: true
  scripts: [ const, proficiency_data, proficiency ]
  autoload: true
  autoload-priority: 1200
  !requiredFeature: g_game.getFeature(GameProficiency)
  dependencies:
    - game_interface
  @onLoad: init()
  @onUnload: terminate()

